{
	"name": "web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "pnpm build:worklet:dev && vite dev",
		"build": "pnpm build:worklet && vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"lint": "prettier --check . && eslint .",
		"format": "prettier --write .",
		"build:worklet": "esbuild src/lib/audio/synth-processor.ts --bundle --format=iife --outfile=static/worklet/synth-processor.js --target=es2020 --define:DEV_MODE=false --minify-syntax",
		"build:worklet:dev": "esbuild src/lib/audio/synth-processor.ts --bundle --format=iife --outfile=static/worklet/synth-processor.js --target=es2020 --sourcemap=inline --define:DEV_MODE=true",
		"build:worklet:watch": "esbuild src/lib/audio/synth-processor.ts --bundle --format=iife --outfile=static/worklet/synth-processor.js --target=es2020 --sourcemap=inline --define:DEV_MODE=true --watch",
		"test:unit": "vitest",
		"test": "npm run test:unit -- --run",
		"storybook": "storybook dev -p 6006",
		"build-storybook": "storybook build"
	},
	"devDependencies": {
		"@eslint/compat": "^2.0.4",
		"@eslint/js": "^10.0.1",
		"@sveltejs/adapter-static": "^3.0.10",
		"@sveltejs/kit": "^2.57.0",
		"@sveltejs/vite-plugin-svelte": "^7.0.0",
		"@types/node": "^24",
		"@vitest/browser-playwright": "^4.1.3",
		"esbuild": "^0.28.0",
		"eslint": "^10.2.0",
		"eslint-config-prettier": "^10.1.8",
		"eslint-plugin-svelte": "^3.17.0",
		"globals": "^17.4.0",
		"playwright": "^1.59.1",
		"prettier": "^3.8.1",
		"prettier-plugin-svelte": "^3.5.1",
		"svelte": "^5.55.2",
		"svelte-check": "^4.4.6",
		"typescript": "^6.0.2",
		"typescript-eslint": "^8.58.1",
		"vite": "^8.0.7",
		"vitest": "^4.1.3",
		"vitest-browser-svelte": "^2.1.0"
	}
}
