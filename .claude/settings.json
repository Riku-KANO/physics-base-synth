{
	"$schema": "https://json.schemastore.org/claude-code-settings.json",
	"hooks": {
		"PostToolUse": [
			{
				"matcher": "Write|Edit|MultiEdit",
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/scripts/format-on-edit.sh",
						"shell": "bash",
						"timeout": 30,
						"statusMessage": "Auto-formatting edited file..."
					}
				]
			}
		],
		"Stop": [
			{
				"hooks": [
					{
						"type": "command",
						"command": "bash .claude/scripts/lint-check.sh",
						"shell": "bash",
						"timeout": 180,
						"statusMessage": "Running lint check..."
					}
				]
			}
		]
	}
}
